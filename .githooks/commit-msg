#!/usr/bin/env bash
# commit-msg Hook: Bumpt die Version automatisch via Conventional Commits
# fix:  → patch  (0.3.0 → 0.3.1)
# feat: → minor  (0.3.0 → 0.4.0)
# feat!: / BREAKING CHANGE → major (0.3.0 → 1.0.0)

COMMIT_MSG=$(cat "$1")

# Bump-Typ bestimmen
if echo "$COMMIT_MSG" | grep -qE "^[a-z]+(\(.+\))?!:|^BREAKING CHANGE"; then
  BUMP="major"
elif echo "$COMMIT_MSG" | grep -qE "^feat(\(.+\))?:"; then
  BUMP="minor"
elif echo "$COMMIT_MSG" | grep -qE "^fix(\(.+\))?:"; then
  BUMP="patch"
else
  # Kein Conventional-Commit-Präfix → keine Versionsänderung
  exit 0
fi

# Version bumpen
node scripts/bump-version.js "$BUMP"
if [ $? -ne 0 ]; then
  echo "❌ Versions-Bump fehlgeschlagen"
  exit 1
fi

# Geänderte Dateien zum Commit hinzufügen
git add package.json package-lock.json src-tauri/tauri.conf.json RELEASE_NOTES.md 2>/dev/null

echo "✓ Versions-Bump ($BUMP) — bereit zum Commit"
